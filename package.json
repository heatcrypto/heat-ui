{
  "name": "heatwallet",
  "version": "4.3.5",
  "description": "Heat Ledger Generic Client Framework",
  "author": "HEAT",
  "homepage": "https://heatwallet.com",
  "license": "MIT",
  "main": "gulpfile.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/heatcrypto/heat-ui.git"
  },
  "bugs": {
    "url": "https://github.com/heatcrypto/heat-ui/issues"
  },
  "scripts": {
    "pack": "build --dir",
    "dist": "build"
  },
  "engines": {
    "npm": "5.6.0",
    "node": "8.10.0"
  },
  "devDependencies": {
    "@types/angular": "^1.7.3",
    "@types/angular-animate": "^1.5.10",
    "@types/angular-material": "^1.1.71",
    "@types/angular-scroll": "0.0.31",
    "@types/bytebuffer": "^5.0.41",
    "@types/file-saver": "^2.0.2",
    "@types/jsbn": "^1.2.29",
    "@types/long": "^3.0.32",
    "@types/webrtc": "0.0.26",
    "clipboard": "^2.0.6",
    "connect": "^3.7.0",
    "del": "2.2.2",
    "electron": "3.1.13",
    "electron-builder": "22.8.0",
    "electron-builder-squirrel-windows": "22.8.1",
    "electron-packager": "14.2.1",
    "es6-promise": "3.3.1",
    "gulp": "^4.0.2",
    "gulp-concat": "^2.6.1",
    "gulp-less": "^4.0.1",
    "gulp-lesshint": "^3.0.1",
    "gulp-minify-css": "1.2.4",
    "gulp-minify-html": "1.0.6",
    "gulp-noop": "^1.0.1",
    "gulp-plumber": "^1.2.1",
    "gulp-rename": "^1.4.0",
    "gulp-replace": "0.5.4",
    "gulp-rev": "^7.1.2",
    "gulp-rev-replace": "^0.4.3",
    "gulp-sourcemaps": "1.6.0",
    "gulp-typescript": "^5.0.1",
    "gulp-uglify": "2.0.0",
    "gulp-usemin": "^0.3.30",
    "open": "^7.4.2",
    "random-hash": "^4.0.1",
    "serve-static": "^1.14.1",
    "typescript": "^4.0.5"
  },
  "dependencies": {
    "angular": "^1.8.0",
    "angular-animate": "1.8.0",
    "angular-aria": "1.8.0",
    "angular-material": "1.1.24",
    "angular-material-data-table": "0.10.10",
    "angular-messages": "1.8.0",
    "angular-new-router": "0.5.3",
    "angular-route": "1.8.0",
    "angular-sanitize": "1.8.0",
    "angular-scroll": "^1.0.2",
    "angular-ui-scroll": "^1.8.1",
    "angularjs-scroll-glue": "^2.2.0",
    "big.js": "^3.1.3",
    "bitcore-explorers": "^1.0.1",
    "bytebuffer": "5.0.1",
    "child-process-promise": "^2.2.0",
    "dateformat": "1.0.12",
    "file-saver": "^2.0.5",
    "heat-libs": "github:heatcrypto/heat-libs#release-coins",
    "jsonformatter": "^0.6.0",
    "long": "3.2.0",
    "material-design-icons": "2.2.3",
    "material-design-icons-iconfont": "^6.1.0",
    "ng-popover": "^2.0.0",
    "pako": "1.0.3",
    "techan": "0.8.0",
    "webrtc-adapter": "8.1.0"
  },
  "build": {
    "appId": "com.heatledger.heatwallet",
    "copyright": "Copyright © 2020 HEAT",
    "productName": "Heatwallet",
    "compression": "normal",
    "extraResources": [
      {
        "from": "../heatledger/build/install/heatledger",
        "to": "heatledger"
      }
    ],
    "extraFiles": [
      {
        "from": "./dist/app-config.json",
        "to": "app-config.json"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "publisherName": "Tulipfox"
    },
    "linux": {
      "target": "zip"
    },
    "deb": {},
    "mac": {
      "icon": "app/electron/icon.png.icns",
      "category": "public.app-category.finance",
      "target": [
        "zip"
      ]
    },
    "directories": {
      "output": "releases",
      "app": "dist"
    }
  }
}
