{
  "version": "0.1.0",
  "configurations": [
    {
      "args": [
        "task"
      ],
      "name": "Gulp task",
      "program": "${workspaceFolder}/node_modules/gulp/bin/gulp.js",
      "request": "launch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "type": "node"
    },
    {
      "name": "Attach to url with files served from ./dist",
      "type": "chrome",
      "request": "attach",
      "port": 9222,
      "webRoot": "./dist",
      "sourceMaps": true
    }
  ]
}